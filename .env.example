# optional: enables ai-powered weather insights via claude
# get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# required for the rain alarm push notifications.
# generate once with: npx web-push generate-vapid-keys
# paste the result below and restart the server.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# optional: protect /api/rain-alarm/check from public traffic.
# when set, the cron must include "authorization: bearer <secret>" or "?key=<secret>".
RAIN_ALARM_CRON_SECRET=
